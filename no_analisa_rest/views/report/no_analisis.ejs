<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <title>History Nomor Permintaan Analisis</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      font-size: 12px;
      color: #000;
    }

    h2 {
      margin-bottom: 4px;
    }

    /* .header {
      margin-bottom: 20px;
    } */

    table {
      width: 100%;
      border-collapse: collapse;
    }

    th, td {
      border: 1px solid #000;
      padding: 6px;
      text-align: left;
    }

    th {
      background: #eee;
      text-align: center;
    }

    /* .header table {
      border:none;
    }
    
    .header table td {
      border:none;
    }

    .header table td.label {
      width:10%;
    }

    .header table td.titik {
      width:1%;
    } */

    .logo-cell {
    width: 20%;
    text-align: center;
    }

    .logo-cell img {
    /* height: 30px; */
    width: 100px;
    }

    .title-cell {
    width: 80%;
    text-align: center;
    font-size: 18px;
    }

    .header-table {
      width: 100%;
      height: 80px;
      border-collapse: collapse;
      /* border:none; */
    }

    .header-table td {
      vertical-align: middle;
      /* border:none; */
    }

  </style>
</head>
<body>

  <hr style="margin-top: 0px;">
    <table class="header-table">
        <tr>
            <!-- LOGO -->
            <td class="logo-cell">
            <img src="<%= logoUrl %>" alt="LOGO">
            </td>

            <!-- JUDUL -->
            <td class="title-cell">
            <strong>LIST HISTORY PERMINTAAN NOMOR ANALISIS</strong>
            </td>

        </tr>
    </table>
    <hr>
  <table>
    <thead>
      <tr>
        <th>No</th>
        <th>No. Permintaan Analisis</th>
        <th>Departmen</th>
        <th>Jenis Pemeriksaan</th>
        <th>Jenis Sampel</th>
        <th>Admin Entry</th>
        <th>Tanggal</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% data.forEach((row, i) => { %>
        <tr>
          <td style="text-align: center;"><%= i + 1 %></td>
          <td><%= row?.code || '-' %></td>
          <td><%= row?.dept_name || '-' %></td>
          <td><%= row?.sampel_name || '-' %></td>
          <td><%= row?.check_name || '-' %></td>
          <td><%= row?.user_name || '-' %></td>
          <td><%= row?.tgl || '-' %></td>
          <td><%= row?.status || '-' %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <p style="margin-top:20px;">
    <%
      const d = new Date();

      const dd = String(d.getDate()).padStart(2, '0');
      const mm = String(d.getMonth() + 1).padStart(2, '0');
      const yyyy = d.getFullYear();

      const hh = String(d.getHours()).padStart(2, '0');
      const mi = String(d.getMinutes()).padStart(2, '0');
    %>

    Generated at: <%= `${dd}/${mm}/${yyyy} ${hh}:${mi}` %>
  </p>

</body>
</html>
